# OpenAI-kompatible API Konfiguration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Modell (z. B. gpt-4.1-mini, gpt-4o)
OPENAI_MODEL=gpt-4.1-mini

# Optional: interner API-Key zum Schutz des hAI.HAAiI-Endpoints
# Wenn gesetzt, muss jeder Client den Header X-HAI-API-Key mitschicken
HAI_INTERNAL_API_KEY=

# Optional: erlaubte Modelle (Komma-getrennt, leer = alle erlaubt)
HAI_ALLOWED_MODELS=

# Erlaubte Hosts (TrustedHostMiddleware)
HAI_ALLOWED_HOSTS=localhost,127.0.0.1,homeassistant
